# usb-auth: suppress udisks auto-mount for LUKS partition
# Prevents GNOME/udisks from showing passphrase prompt for the auth LUKS partition
# Generated by usb-auth setup — do not edit manually

ENV{ID_FS_UUID}=="{{LUKS_UUID}}", ENV{UDISKS_IGNORE}="1"
ENV{ID_FS_UUID}=="{{LUKS_UUID}}", ENV{UDISKS_AUTO}="0"
