#!/bin/bash
set -o pipefail

_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$_SCRIPT")" && pwd)"
SPELL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
unset _SCRIPT

VENV="$SPELL_DIR/.venv"
if [[ -x "$VENV/bin/python3" ]]; then
    PYTHON="$VENV/bin/python3"
else
    echo "error: mdview is not installed; run 'sigils install mdview' or 'sigils install --dev mdview'" >&2
    exit 1
fi

export SPELL_DIR
export MDVIEW_CALLER_CWD="${PWD}"

cd "$SPELL_DIR" || exit 1
exec "$PYTHON" -m lib.commands "$@"
