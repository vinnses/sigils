#!/usr/bin/env bash

set -euo pipefail

SPELL_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
source "${SPELL_DIR}/lib/core.bash"

_arcane_usage() {
    cat <<'EOF'
Usage:
  arcane <subcommand> [projects...] [--exclude|-e excludes...] [--device|-d device]
  arcane exec [--device|-d device] [--project|-p project] <service> -- <command...>
  arcane list [--device|-d device] [project [containers|images|networks|volumes|all]]
  arcane remove [--device|-d device] [--force|-f] <project> <containers|images|networks|volumes|all>[,<type>...] [names...]
  arcane dump [--only-env|--volumes] [--device|-d device] [--output|-o path] [projects...]
  arcane restore <archive.7z> [--force|-f]

Subcommands:
  up         Start services (docker compose up -d)
  down       Stop services (docker compose down)
  pull       Pull images and restart (pull + up -d)
  restart    Full restart (down + pull + up -d)
  clean      Stop services and remove images for selected projects
  purge      Stop services and remove images and volumes for selected projects
  ps         Show compose service status (docker compose ps)
  list       List projects, or list containers/images/networks/volumes for one project
  exec       Run a command inside one service, resolving the project by service name when unique
  remove     Remove project containers, images, networks, volumes, or all resources (rm also works)
  archive    Move an active project to archived/<device>/<project>
  unarchive  Restore a project from archived/<device>/<project>
  clone      Copy a project from one device to another
  nginx-urls Generate one portable bookmarks HTML with nginx URLs grouped by device/project
  dump       Backup environment files, optionally including Docker volumes
  restore    Restore environment files and volumes from 7z archive

Notes:
  - 'run' has been removed. Use lifecycle commands for project-wide actions.
  - Use 'arcane exec <service> -- bash' instead of the removed bash shortcut.

Options:
  -d, --device <name>     Target device (default: hostname)
  -e, --exclude <names>   Exclude projects from batch operation
  -f, --force             Only for remove/rm: force container/image removal
                          Only for restore: overwrite files and recreate volumes
  -o, --output <path>     Output path for nginx-urls
      --up                Only for list: show running projects
      --down              Only for list: show stopped projects
      --archived          Only for list: show archived projects

Environment:
  ARCANE_DIR   Arcane repository path (default: ~/arcane)
EOF
}

case "${1:-}" in
    up)
        shift
        _arcane_each "docker compose up -d" "$@"
        ;;
    down)
        shift
        _arcane_each "docker compose down" "$@"
        ;;
    pull)
        shift
        _arcane_each "docker compose pull && docker compose up -d" "$@"
        ;;
    restart)
        shift
        _arcane_each "docker compose down && docker compose pull && docker compose up -d" "$@"
        ;;
    clean)
        shift
        _arcane_each "docker compose down --rmi all" "$@"
        ;;
    purge)
        shift
        _arcane_each "docker compose down --rmi all --volumes" "$@"
        ;;
    ps)
        shift
        _arcane_each "docker compose ps" "$@"
        ;;
    list)
        shift
        ls_mode="all"
        seen_up=false
        seen_down=false
        seen_archived=false
        ls_args=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --up)
                    seen_up=true
                    ls_mode="up"
                    shift
                    ;;
                --down)
                    seen_down=true
                    ls_mode="down"
                    shift
                    ;;
                --archived)
                    seen_archived=true
                    shift
                    ;;
                *)
                    ls_args+=("$1")
                    shift
                    ;;
            esac
        done
        if $seen_up && $seen_down; then
            echo "error: choose only one of --up or --down" >&2
            exit 1
        fi
        if $seen_archived; then
            if $seen_up || $seen_down; then
                echo "error: --archived cannot be combined with --up or --down" >&2
                exit 1
            fi
            _arcane_ls_archived "${ls_args[@]}"
        else
            _arcane_ls "$ls_mode" "${ls_args[@]}"
        fi
        ;;
    exec)
        shift
        _arcane_exec "$@"
        ;;
    remove|rm)
        shift
        _arcane_remove "$@"
        ;;
    archive)
        shift
        _arcane_archive "$@"
        ;;
    unarchive)
        shift
        _arcane_unarchive "$@"
        ;;
    clone)
        shift
        _arcane_clone "$@"
        ;;
    run)
        echo "error: run has been removed. Use 'arcane exec <service> -- <command...>' or a lifecycle subcommand." >&2
        exit 1
        ;;
    nginx-urls)
        shift
        _arcane_nginx_urls "$@"
        ;;
    dump)
        shift
        _arcane_dump "$@"
        ;;
    restore)
        shift
        if [[ $# -lt 1 ]]; then
            echo "error: restore requires an archive path" >&2
            exit 1
        fi
        _arcane_restore "$@"
        ;;
    --help|-h|help)
        _arcane_usage
        ;;
    "")
        _arcane_usage
        exit 1
        ;;
    *)
        echo "error: unknown subcommand: $1" >&2
        _arcane_usage
        exit 1
        ;;
esac
