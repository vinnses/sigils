#!/usr/bin/env bash

set -euo pipefail

SPELL_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
source "${SPELL_DIR}/lib/core.bash"

_arcane_usage() {
    cat <<'EOF'
Usage:
  arcane <subcommand> [projects...] [--exclude|-e excludes...] [--device|-d device]
  arcane exec [--device|-d device] [--project|-p project] <service> -- <command...>
  arcane bash [--device|-d device] [--project|-p project] <service>
  arcane rm <containers|images|networks|volumes|all> [projects...] [--exclude|-e excludes...] [--device|-d device]

Subcommands:
  up         Start services (docker compose up -d)
  down       Stop services (docker compose down)
  pull       Pull images and restart (pull + up -d)
  restart    Full restart (down + pull + up -d)
  clean      Legacy cleanup shortcut (down --rmi all)
  purge      Legacy cleanup shortcut with volumes (down --rmi all --volumes)
  status     Show service status (docker compose ps)
  ls         List projects on device (optionally only up or down)
  cd         Shell helper when sourced; otherwise prints the project path
  path       Print the absolute path for one project
  exec       Run a command inside one service, resolving the project by service name when unique
  bash       Open bash in one service, resolving the project by service name when unique
  resources  Show containers, images, networks, and volumes tied to projects
  rm         Remove one resource type for the selected projects
  favorites  Generate one portable bookmarks HTML with nginx URLs grouped by device/project
  dump       Backup all .env files to encrypted 7z archive
  restore    Restore .env files from 7z archive

Notes:
  - 'run' has been removed. Use lifecycle commands for project-wide actions.
  - For shell navigation, source init/env.bash and use: arcane cd <project>
  - Non-interactive path lookup remains available via: arcane path <project>

Options:
  -d, --device <name>     Target device (default: hostname)
  -e, --exclude <names>   Exclude projects from batch operation
  -o, --output <path>     Output path for favorites (only with favorites)
      --up                Only for ls: show running projects
      --down              Only for ls: show stopped projects

Environment:
  ARCANE_DIR   Arcane repository path (default: ~/arcane)
EOF
}

case "${1:-}" in
    up)
        shift
        _arcane_each "docker compose up -d" "$@"
        ;;
    down)
        shift
        _arcane_each "docker compose down" "$@"
        ;;
    pull)
        shift
        _arcane_each "docker compose pull && docker compose up -d" "$@"
        ;;
    restart)
        shift
        _arcane_each "docker compose down && docker compose pull && docker compose up -d" "$@"
        ;;
    clean)
        shift
        _arcane_each "docker compose down --rmi all" "$@"
        ;;
    purge)
        shift
        _arcane_each "docker compose down --rmi all --volumes" "$@"
        ;;
    status)
        shift
        _arcane_each "docker compose ps" "$@"
        ;;
    ls)
        shift
        ls_mode="all"
        seen_up=false
        seen_down=false
        ls_args=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --up)
                    seen_up=true
                    ls_mode="up"
                    shift
                    ;;
                --down)
                    seen_down=true
                    ls_mode="down"
                    shift
                    ;;
                *)
                    ls_args+=("$1")
                    shift
                    ;;
            esac
        done
        if $seen_up && $seen_down; then
            echo "error: choose only one of --up or --down" >&2
            exit 1
        fi
        _arcane_ls "$ls_mode" "${ls_args[@]}"
        ;;
    cd|path)
        shift
        _arcane_path "$@"
        ;;
    exec)
        shift
        _arcane_exec "$@"
        ;;
    bash)
        shift
        _arcane_bash "$@"
        ;;
    resources)
        shift
        _arcane_resources "$@"
        ;;
    rm)
        shift
        [[ $# -gt 0 ]] || { echo "error: rm requires a resource type" >&2; exit 1; }
        resource_type="$1"
        shift
        _arcane_rm "$resource_type" "$@"
        ;;
    run)
        echo "error: run has been removed. Use 'arcane exec <service> -- <command...>' or a lifecycle subcommand." >&2
        exit 1
        ;;
    favorites)
        shift
        _arcane_favorites "$@"
        ;;
    dump)
        _arcane_dump
        ;;
    restore)
        shift
        if [[ $# -lt 1 ]]; then
            echo "error: restore requires an archive path" >&2
            exit 1
        fi
        _arcane_restore "$1"
        ;;
    --help|-h|help)
        _arcane_usage
        ;;
    "")
        _arcane_usage
        exit 1
        ;;
    *)
        echo "error: unknown subcommand: $1" >&2
        _arcane_usage
        exit 1
        ;;
esac
