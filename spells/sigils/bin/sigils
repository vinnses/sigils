#!/usr/bin/env bash

set -euo pipefail

SPELL_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
source "$SPELL_DIR/../../lib/common/spells.bash"
source "$SPELL_DIR/../../lib/common/rites.bash"

usage() {
    cat <<'EOF'
Usage:
  sigils list
  sigils link
  sigils unlink
  sigils executable
  sigils enable <spell>
  sigils disable <spell>
  sigils new <spell>
  sigils install [--dev] [--all|<spell>]
  sigils test [--all|<spell>]
  sigils check [--all|<spell>]
  sigils fmt [--all|<spell>]
  sigils clean [--all|<spell>]
  sigils man <spell>
  sigils cd <spell>
  sigils rites
  sigils rites list
  sigils rites path <rite>
  sigils rites docs <rite>
  sigils rite <rite> [args...]
EOF
}

require_spell() {
    local spell="$1"
    if ! sigils_spell_exists "$spell"; then
        echo "error: unknown spell: $spell" >&2
        exit 1
    fi
}

require_rite() {
    local rite="$1"
    if ! sigils_rite_entrypoint "$rite" >/dev/null; then
        echo "error: unknown rite: $rite" >&2
        exit 1
    fi
}

run_rite_target() {
    local rite="$1"
    local subcommand="$2"

    require_rite "$rite"
    "$(sigils_rite_entrypoint "$rite")" "$subcommand"
}

run_rites_target() {
    local subcommand="$1"
    local selector="${2:---all}"
    local matched=false

    if [[ "$selector" == "--all" ]]; then
        while IFS=$'\t' read -r rite _rite_dir; do
            matched=true
            run_rite_target "$rite" "$subcommand"
        done < <(sigils_iter_rites)
    else
        matched=true
        run_rite_target "$selector" "$subcommand"
    fi

    $matched || {
        echo "error: no rites found" >&2
        exit 1
    }
}

run_make() {
    local target="$1"
    shift || true

    make -C "$SIGILS_ROOT" "$target" "$@"
}

parse_spell_selector() {
    SELECTED_SPELL=""
    SELECT_ALL=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)
                SELECT_ALL=true
                shift
                ;;
            -*)
                echo "error: unknown option: $1" >&2
                exit 1
                ;;
            *)
                if [[ -n "$SELECTED_SPELL" ]]; then
                    echo "error: expected at most one spell name" >&2
                    exit 1
                fi
                SELECTED_SPELL="$1"
                shift
                ;;
        esac
    done

    if $SELECT_ALL && [[ -n "$SELECTED_SPELL" ]]; then
        echo "error: choose either one spell or --all" >&2
        exit 1
    fi
}

run_spell_target() {
    local target="$1"
    shift || true

    parse_spell_selector "$@"

    if [[ -n "$SELECTED_SPELL" ]]; then
        require_spell "$SELECTED_SPELL"
        run_make "$target" "SPELL=$SELECTED_SPELL"
        return
    fi

    run_make "$target"
}

render_spell_doc() {
    local spell="$1"
    local doc_path
    doc_path="$(sigils_spell_doc_path "$spell")" || {
        echo "error: no documentation found for spell: $spell" >&2
        exit 1
    }

    cat "$doc_path"
}

case "${1:-}" in
    list)
        while IFS=$'\t' read -r spell status _spell_dir; do
            printf '%s %s\n' "$status" "$spell"
        done < <(sigils_iter_spells)
        ;;
    link|unlink|executable)
        run_make "$1"
        ;;
    enable)
        [[ $# -eq 2 ]] || { echo "error: enable requires a spell name" >&2; exit 1; }
        require_spell "$2"
        sigils_enable_spell "$2"
        ;;
    disable)
        [[ $# -eq 2 ]] || { echo "error: disable requires a spell name" >&2; exit 1; }
        require_spell "$2"
        sigils_disable_spell "$2"
        ;;
    new)
        [[ $# -eq 2 ]] || { echo "error: new requires a spell name" >&2; exit 1; }
        run_make new "SPELL=$2"
        ;;
    install)
        shift
        target="install"
        if [[ "${1:-}" == "--dev" ]]; then
            target="install-dev"
            shift
        fi
        run_spell_target "$target" "$@"
        ;;
    test|check|fmt|clean)
        target="$1"
        shift
        run_spell_target "$target" "$@"
        ;;
    man)
        [[ $# -eq 2 ]] || { echo "error: man requires a spell name" >&2; exit 1; }
        require_spell "$2"
        render_spell_doc "$2"
        ;;
    cd)
        [[ $# -eq 2 ]] || { echo "error: cd requires a spell name" >&2; exit 1; }
        require_spell "$2"
        sigils_spell_dir "$2"
        ;;
    rites)
        case "${2:-list}" in
            list)
                while IFS=$'\t' read -r rite _rite_dir; do
                    printf '%s\n' "$rite"
                done < <(sigils_iter_rites)
                ;;
            path)
                [[ $# -eq 3 ]] || { echo "error: rites path requires a rite name" >&2; exit 1; }
                require_rite "$3"
                sigils_rite_dir "$3"
                ;;
            docs)
                [[ $# -eq 3 ]] || { echo "error: rites docs requires a rite name" >&2; exit 1; }
                require_rite "$3"
                cat "$(sigils_rite_doc_path "$3")"
                ;;
            status)
                [[ $# -le 3 ]] || { echo "error: rites status accepts at most one selector" >&2; exit 1; }
                run_rites_target status "${3:---all}"
                ;;
            doctor)
                [[ $# -le 3 ]] || { echo "error: rites doctor accepts at most one selector" >&2; exit 1; }
                run_rites_target doctor "${3:---all}"
                ;;
            *)
                echo "error: unknown rites subcommand: ${2:-}" >&2
                exit 1
                ;;
        esac
        ;;
    rite)
        [[ $# -ge 2 ]] || { echo "error: rite requires a rite name" >&2; exit 1; }
        require_rite "$2"
        rite_entrypoint="$(sigils_rite_entrypoint "$2")"
        shift 2
        exec "$rite_entrypoint" "$@"
        ;;
    --help|-h|help|"")
        usage
        [[ $# -gt 0 ]] || exit 1
        ;;
    *)
        echo "error: unknown subcommand: $1" >&2
        usage
        exit 1
        ;;
esac
