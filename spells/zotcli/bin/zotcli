#!/bin/bash
# zotcli — raw binary entrypoint (v3)
# Routes subcommands to Python. Called via `command zotcli` (bypasses shell wrapper).
set -o pipefail

_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$_SCRIPT")" && pwd)"
SPELL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
unset _SCRIPT

# Use venv Python if available
VENV="$SPELL_DIR/.venv"
if [[ -d "$VENV" ]]; then
    PYTHON="$VENV/bin/python3"
else
    PYTHON="python3"
fi

# Parse global flags
FRESH=false
ARGS=()
for arg in "$@"; do
    [[ "$arg" == "--fresh" ]] && FRESH=true || ARGS+=("$arg")
done

SUBCOMMAND="${ARGS[0]:-}"
SUBARGS=("${ARGS[@]:1}")

export SPELL_DIR
export ZOTCLI_FRESH="$FRESH"

case "$SUBCOMMAND" in
    -h|--help|help)
        exec "$PYTHON" "$SPELL_DIR/lib/commands.py" help "${SUBARGS[@]}"
        ;;
    py)
        exec "$PYTHON" "$SPELL_DIR/lib/shell_py.py" "${SUBARGS[@]}"
        ;;
    "")
        echo "Usage: zotcli <command> [args]. Try 'zotcli --help'." >&2
        echo "" >&2
        echo "Navigation:  cd [path]  pwd  tree [--depth N]" >&2
        echo "Listing:     ls [path] [--sort <f>] [--reverse] [--unfiled]" >&2
        echo "Reading:     cat <item>[:<child>]" >&2
        echo "Searching:   find <pattern> [--field <f>] [--scope library] [--tag <t>] [--type <t>]" >&2
        echo "Exporting:   get <item> [--bibtex|--json|--bib] [--style <csl>]" >&2
        echo "             get <item>:<child> [-o <path>]" >&2
        echo "Setup:       connect  sync  config [key [value]]" >&2
        echo "Prompt:      prompt --on [--color <name>]  prompt --off  prompt (toggle)" >&2
        echo "Python:      py  py -c '<code>'  py <script.py>" >&2
        echo "" >&2
        echo "Global flags: --fresh" >&2
        exit 1
        ;;
    *)
        exec "$PYTHON" "$SPELL_DIR/lib/commands.py" "$SUBCOMMAND" "${SUBARGS[@]}"
        ;;
esac
